# Project environment template
# Copy to .env before using remote D1/KV development mode.

# Cloudflare account credentials (required for wrangler remote operations)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare remote resource IDs (required by scripts/prepare-remote-config.mjs)
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_KV_HOT_ID=

# Local dev base port (optional, used by `bun run dev`)
DEV_PORT=8787
